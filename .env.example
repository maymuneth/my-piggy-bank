# ── Privy ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# ── Starknet RPC (optional — Starkzap has defaults) ───────────────────────────
# Get a free key from https://www.alchemy.com or https://blast.io
NEXT_PUBLIC_STARKNET_RPC=https://starknet-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── AVNU Paymaster (gasless transactions) ────────────────────────────────────
# Get from https://app.avnu.fi/en/paymaster
NEXT_PUBLIC_AVNU_API_KEY=your_avnu_api_key_here
